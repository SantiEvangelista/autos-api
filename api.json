{
    "openapi": "3.1.0",
    "info": {
        "title": "API  Autos",
        "version": "1.0.0",
        "description": "API p\u00fablica para consultar valuaciones de veh\u00edculos del mercado argentino. Modelo de datos: Brand \u2192 CarModel \u2192 Version \u2192 Valuation. Rate limit: 60 req/min por IP."
    },
    "servers": [
        {
            "url": "http://localhost:8080/api"
        }
    ],
    "paths": {
        "/brands": {
            "get": {
                "operationId": "brands.index",
                "description": "Returns all vehicle brands ordered alphabetically, paginated.\nUses `simplePaginate` \u2014 response does not include `total`.",
                "summary": "List all brands",
                "tags": [
                    "Brand"
                ],
                "parameters": [
                    {
                        "name": "per_page",
                        "in": "query",
                        "schema": {
                            "type": "integer",
                            "default": 50
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Paginated set of `BrandResource`",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "type": "object",
                                    "properties": {
                                        "data": {
                                            "type": "array",
                                            "items": {
                                                "$ref": "#/components/schemas/BrandResource"
                                            }
                                        },
                                        "links": {
                                            "type": "object",
                                            "properties": {
                                                "first": {
                                                    "type": [
                                                        "string",
                                                        "null"
                                                    ]
                                                },
                                                "last": {
                                                    "type": [
                                                        "string",
                                                        "null"
                                                    ]
                                                },
                                                "prev": {
                                                    "type": [
                                                        "string",
                                                        "null"
                                                    ]
                                                },
                                                "next": {
                                                    "type": [
                                                        "string",
                                                        "null"
                                                    ]
                                                }
                                            },
                                            "required": [
                                                "first",
                                                "last",
                                                "prev",
                                                "next"
                                            ]
                                        },
                                        "meta": {
                                            "type": "object",
                                            "properties": {
                                                "current_page": {
                                                    "type": "integer",
                                                    "minimum": 1
                                                },
                                                "from": {
                                                    "type": [
                                                        "integer",
                                                        "null"
                                                    ],
                                                    "minimum": 1
                                                },
                                                "path": {
                                                    "type": [
                                                        "string",
                                                        "null"
                                                    ],
                                                    "description": "Base path for paginator generated URLs."
                                                },
                                                "per_page": {
                                                    "type": "integer",
                                                    "description": "Number of items shown per page.",
                                                    "minimum": 0
                                                },
                                                "to": {
                                                    "type": [
                                                        "integer",
                                                        "null"
                                                    ],
                                                    "description": "Number of the last item in the slice.",
                                                    "minimum": 1
                                                }
                                            },
                                            "required": [
                                                "current_page",
                                                "from",
                                                "path",
                                                "per_page",
                                                "to"
                                            ]
                                        }
                                    },
                                    "required": [
                                        "data",
                                        "links",
                                        "meta"
                                    ]
                                }
                            }
                        }
                    }
                }
            }
        },
        "/brands/{brand}/models": {
            "get": {
                "operationId": "brands.models",
                "description": "Returns all car models belonging to a brand, identified by its slug.\nUse `relations[]=brand` to include the parent brand data in each model.",
                "summary": "List models for a brand",
                "tags": [
                    "Brand"
                ],
                "parameters": [
                    {
                        "name": "brand",
                        "in": "path",
                        "required": true,
                        "description": "The brand slug",
                        "schema": {
                            "type": "string"
                        }
                    },
                    {
                        "name": "relations[]",
                        "in": "query",
                        "schema": {
                            "type": "array",
                            "enum": [
                                "brand"
                            ],
                            "items": {
                                "type": "string",
                                "enum": [
                                    "brand"
                                ]
                            }
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Array of `CarModelResource`",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "type": "object",
                                    "properties": {
                                        "data": {
                                            "type": "array",
                                            "items": {
                                                "$ref": "#/components/schemas/CarModelResource"
                                            }
                                        }
                                    },
                                    "required": [
                                        "data"
                                    ]
                                }
                            }
                        }
                    },
                    "404": {
                        "$ref": "#/components/responses/ModelNotFoundException"
                    },
                    "422": {
                        "$ref": "#/components/responses/ValidationException"
                    }
                }
            }
        },
        "/models/{carModel}/versions": {
            "get": {
                "operationId": "models.versions",
                "description": "Returns all versions belonging to a car model, paginated.\nUse `relations[]` to include parent model and/or brand data in each version.",
                "summary": "List versions for a model",
                "tags": [
                    "CarModel"
                ],
                "parameters": [
                    {
                        "name": "carModel",
                        "in": "path",
                        "required": true,
                        "description": "The car model ID",
                        "schema": {
                            "type": "integer"
                        }
                    },
                    {
                        "name": "relations[]",
                        "in": "query",
                        "schema": {
                            "type": "array",
                            "enum": [
                                "model",
                                "brand"
                            ],
                            "items": {
                                "type": "string",
                                "enum": [
                                    "model",
                                    "brand"
                                ]
                            }
                        }
                    },
                    {
                        "name": "page",
                        "in": "query",
                        "schema": {
                            "type": "integer",
                            "minimum": 1
                        }
                    },
                    {
                        "name": "per_page",
                        "in": "query",
                        "schema": {
                            "type": "integer",
                            "minimum": 1,
                            "maximum": 100
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Paginated set of `VersionResource`",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "type": "object",
                                    "properties": {
                                        "data": {
                                            "type": "array",
                                            "items": {
                                                "$ref": "#/components/schemas/VersionResource"
                                            }
                                        },
                                        "links": {
                                            "type": "object",
                                            "properties": {
                                                "first": {
                                                    "type": [
                                                        "string",
                                                        "null"
                                                    ]
                                                },
                                                "last": {
                                                    "type": [
                                                        "string",
                                                        "null"
                                                    ]
                                                },
                                                "prev": {
                                                    "type": [
                                                        "string",
                                                        "null"
                                                    ]
                                                },
                                                "next": {
                                                    "type": [
                                                        "string",
                                                        "null"
                                                    ]
                                                }
                                            },
                                            "required": [
                                                "first",
                                                "last",
                                                "prev",
                                                "next"
                                            ]
                                        },
                                        "meta": {
                                            "type": "object",
                                            "properties": {
                                                "current_page": {
                                                    "type": "integer",
                                                    "minimum": 1
                                                },
                                                "from": {
                                                    "type": [
                                                        "integer",
                                                        "null"
                                                    ],
                                                    "minimum": 1
                                                },
                                                "path": {
                                                    "type": [
                                                        "string",
                                                        "null"
                                                    ],
                                                    "description": "Base path for paginator generated URLs."
                                                },
                                                "per_page": {
                                                    "type": "integer",
                                                    "description": "Number of items shown per page.",
                                                    "minimum": 0
                                                },
                                                "to": {
                                                    "type": [
                                                        "integer",
                                                        "null"
                                                    ],
                                                    "description": "Number of the last item in the slice.",
                                                    "minimum": 1
                                                }
                                            },
                                            "required": [
                                                "current_page",
                                                "from",
                                                "path",
                                                "per_page",
                                                "to"
                                            ]
                                        }
                                    },
                                    "required": [
                                        "data",
                                        "links",
                                        "meta"
                                    ]
                                }
                            }
                        }
                    },
                    "404": {
                        "$ref": "#/components/responses/ModelNotFoundException"
                    },
                    "422": {
                        "$ref": "#/components/responses/ValidationException"
                    }
                }
            }
        },
        "/health": {
            "get": {
                "operationId": "health",
                "description": "Verifies connectivity to all service dependencies: PostgreSQL, Redis,\nand availability of the cached exchange rate.\nReturns 200 when healthy, 503 when degraded.",
                "summary": "Health check",
                "tags": [
                    "Health"
                ],
                "responses": {
                    "200": {
                        "description": "",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "type": "string"
                                }
                            }
                        }
                    },
                    "503": {
                        "description": "Service degraded. At least one critical dependency (database or redis) is unavailable.",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "type": "object",
                                    "properties": {
                                        "status": {
                                            "type": "string",
                                            "example": "degraded"
                                        },
                                        "checks": {
                                            "type": "object",
                                            "properties": {
                                                "database": {
                                                    "type": "string",
                                                    "example": "ok"
                                                },
                                                "redis": {
                                                    "type": "string",
                                                    "example": "error"
                                                },
                                                "exchange_rate_cached": {
                                                    "type": "string",
                                                    "example": "not_cached"
                                                }
                                            }
                                        }
                                    }
                                }
                            }
                        }
                    }
                }
            }
        },
        "/search": {
            "get": {
                "operationId": "search",
                "description": "Full-text, case-insensitive search across version names, model names and brand names.\nReturns paginated results with brand, model and version info flattened.",
                "summary": "Search versions, models and brands",
                "tags": [
                    "Search"
                ],
                "parameters": [
                    {
                        "name": "q",
                        "in": "query",
                        "required": true,
                        "schema": {
                            "type": "string",
                            "minLength": 2
                        }
                    },
                    {
                        "name": "page",
                        "in": "query",
                        "schema": {
                            "type": "integer",
                            "minimum": 1
                        }
                    },
                    {
                        "name": "per_page",
                        "in": "query",
                        "schema": {
                            "type": "integer",
                            "minimum": 1,
                            "maximum": 50
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Paginated set of `SearchResultResource`",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "type": "object",
                                    "properties": {
                                        "data": {
                                            "type": "array",
                                            "items": {
                                                "$ref": "#/components/schemas/SearchResultResource"
                                            }
                                        },
                                        "links": {
                                            "type": "object",
                                            "properties": {
                                                "first": {
                                                    "type": [
                                                        "string",
                                                        "null"
                                                    ]
                                                },
                                                "last": {
                                                    "type": [
                                                        "string",
                                                        "null"
                                                    ]
                                                },
                                                "prev": {
                                                    "type": [
                                                        "string",
                                                        "null"
                                                    ]
                                                },
                                                "next": {
                                                    "type": [
                                                        "string",
                                                        "null"
                                                    ]
                                                }
                                            },
                                            "required": [
                                                "first",
                                                "last",
                                                "prev",
                                                "next"
                                            ]
                                        },
                                        "meta": {
                                            "type": "object",
                                            "properties": {
                                                "current_page": {
                                                    "type": "integer",
                                                    "minimum": 1
                                                },
                                                "from": {
                                                    "type": [
                                                        "integer",
                                                        "null"
                                                    ],
                                                    "minimum": 1
                                                },
                                                "path": {
                                                    "type": [
                                                        "string",
                                                        "null"
                                                    ],
                                                    "description": "Base path for paginator generated URLs."
                                                },
                                                "per_page": {
                                                    "type": "integer",
                                                    "description": "Number of items shown per page.",
                                                    "minimum": 0
                                                },
                                                "to": {
                                                    "type": [
                                                        "integer",
                                                        "null"
                                                    ],
                                                    "description": "Number of the last item in the slice.",
                                                    "minimum": 1
                                                }
                                            },
                                            "required": [
                                                "current_page",
                                                "from",
                                                "path",
                                                "per_page",
                                                "to"
                                            ]
                                        }
                                    },
                                    "required": [
                                        "data",
                                        "links",
                                        "meta"
                                    ]
                                }
                            }
                        }
                    },
                    "422": {
                        "$ref": "#/components/responses/ValidationException"
                    }
                }
            }
        },
        "/versions/{version}/valuations": {
            "get": {
                "operationId": "versions.valuations",
                "description": "Returns price valuations by year for a specific vehicle version, ordered by year descending.\nPrices are stored in USD and can be converted to ARS using the official exchange rate (source: Bluelytics).\n\nUse `format_price=true` to include a human-readable formatted price string.\nUse `relations[]` to include version/model/brand metadata.",
                "summary": "Get valuations for a version",
                "tags": [
                    "Version"
                ],
                "parameters": [
                    {
                        "name": "version",
                        "in": "path",
                        "required": true,
                        "description": "The version ID",
                        "schema": {
                            "type": "integer"
                        }
                    },
                    {
                        "name": "currency",
                        "in": "query",
                        "schema": {
                            "type": "string",
                            "enum": [
                                "ARS",
                                "USD"
                            ]
                        }
                    },
                    {
                        "name": "format_price",
                        "in": "query",
                        "schema": {
                            "type": "string",
                            "enum": [
                                "true",
                                "false",
                                "1",
                                "0"
                            ]
                        }
                    },
                    {
                        "name": "relations[]",
                        "in": "query",
                        "schema": {
                            "type": "array",
                            "enum": [
                                "version",
                                "model",
                                "brand"
                            ],
                            "items": {
                                "type": "string",
                                "enum": [
                                    "version",
                                    "model",
                                    "brand"
                                ]
                            }
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Array of `ValuationResource`",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "type": "object",
                                    "properties": {
                                        "data": {
                                            "type": "array",
                                            "items": {
                                                "$ref": "#/components/schemas/ValuationResource"
                                            }
                                        },
                                        "meta": {
                                            "type": "object",
                                            "properties": {
                                                "currency": {},
                                                "version": {
                                                    "type": "string"
                                                },
                                                "model": {
                                                    "type": "object",
                                                    "properties": {
                                                        "name": {
                                                            "type": "string"
                                                        },
                                                        "slug": {
                                                            "type": "string"
                                                        }
                                                    },
                                                    "required": [
                                                        "name",
                                                        "slug"
                                                    ]
                                                },
                                                "brand": {
                                                    "type": "object",
                                                    "properties": {
                                                        "name": {
                                                            "type": "string"
                                                        },
                                                        "slug": {
                                                            "type": "string"
                                                        }
                                                    },
                                                    "required": [
                                                        "name",
                                                        "slug"
                                                    ]
                                                },
                                                "exchange_rate": {
                                                    "type": "object",
                                                    "properties": {
                                                        "source": {
                                                            "type": "string",
                                                            "const": "bluelytics"
                                                        },
                                                        "type": {
                                                            "type": "string",
                                                            "const": "oficial_sell"
                                                        },
                                                        "ars_per_usd": {
                                                            "type": [
                                                                "number",
                                                                "null"
                                                            ]
                                                        }
                                                    },
                                                    "required": [
                                                        "source",
                                                        "type",
                                                        "ars_per_usd"
                                                    ]
                                                }
                                            },
                                            "required": [
                                                "currency",
                                                "version",
                                                "model",
                                                "brand",
                                                "exchange_rate"
                                            ]
                                        }
                                    },
                                    "required": [
                                        "data",
                                        "meta"
                                    ]
                                }
                            }
                        }
                    },
                    "503": {
                        "description": "Exchange rate temporarily unavailable. Only returned when `currency=ARS` and the external rate API is down.",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "type": "object",
                                    "properties": {
                                        "error": {
                                            "type": "string",
                                            "example": "Exchange rate temporarily unavailable"
                                        }
                                    }
                                }
                            }
                        }
                    },
                    "404": {
                        "$ref": "#/components/responses/ModelNotFoundException"
                    },
                    "422": {
                        "$ref": "#/components/responses/ValidationException"
                    }
                }
            }
        }
    },
    "components": {
        "schemas": {
            "BrandResource": {
                "type": "object",
                "properties": {
                    "id": {
                        "type": "integer"
                    },
                    "name": {
                        "type": "string"
                    },
                    "slug": {
                        "type": "string"
                    }
                },
                "required": [
                    "id",
                    "name",
                    "slug"
                ],
                "title": "BrandResource"
            },
            "CarModelResource": {
                "type": "object",
                "properties": {
                    "id": {
                        "type": "integer"
                    },
                    "brand_id": {
                        "type": "integer"
                    },
                    "name": {
                        "type": "string"
                    },
                    "slug": {
                        "type": "string"
                    },
                    "brand": {
                        "type": "object",
                        "properties": {
                            "name": {
                                "type": "string"
                            },
                            "slug": {
                                "type": "string"
                            }
                        },
                        "required": [
                            "name",
                            "slug"
                        ]
                    }
                },
                "required": [
                    "id",
                    "brand_id",
                    "name",
                    "slug"
                ],
                "title": "CarModelResource"
            },
            "SearchResultResource": {
                "type": "object",
                "properties": {
                    "version_id": {
                        "type": "integer"
                    },
                    "brand": {
                        "type": "string"
                    },
                    "brand_slug": {
                        "type": "string"
                    },
                    "model": {
                        "type": "string"
                    },
                    "model_slug": {
                        "type": "string"
                    },
                    "version": {
                        "type": "string"
                    }
                },
                "required": [
                    "version_id",
                    "brand",
                    "brand_slug",
                    "model",
                    "model_slug",
                    "version"
                ],
                "title": "SearchResultResource"
            },
            "ValuationResource": {
                "type": "object",
                "properties": {
                    "id": {
                        "type": "integer"
                    },
                    "version_id": {
                        "type": "integer"
                    },
                    "year": {
                        "type": "integer"
                    },
                    "price": {
                        "type": "string"
                    },
                    "price_formatted": {
                        "type": "string"
                    }
                },
                "required": [
                    "id",
                    "version_id",
                    "year",
                    "price",
                    "price_formatted"
                ],
                "title": "ValuationResource"
            },
            "VersionResource": {
                "type": "object",
                "properties": {
                    "id": {
                        "type": "integer"
                    },
                    "car_model_id": {
                        "type": "integer"
                    },
                    "name": {
                        "type": "string"
                    },
                    "model": {
                        "type": "object",
                        "properties": {
                            "name": {
                                "type": "string"
                            },
                            "slug": {
                                "type": "string"
                            }
                        },
                        "required": [
                            "name",
                            "slug"
                        ]
                    },
                    "brand": {
                        "type": "object",
                        "properties": {
                            "name": {
                                "type": "string"
                            },
                            "slug": {
                                "type": "string"
                            }
                        },
                        "required": [
                            "name",
                            "slug"
                        ]
                    }
                },
                "required": [
                    "id",
                    "car_model_id",
                    "name"
                ],
                "title": "VersionResource"
            }
        },
        "responses": {
            "ModelNotFoundException": {
                "description": "Not found",
                "content": {
                    "application/json": {
                        "schema": {
                            "type": "object",
                            "properties": {
                                "message": {
                                    "type": "string",
                                    "description": "Error overview."
                                }
                            },
                            "required": [
                                "message"
                            ]
                        }
                    }
                }
            },
            "ValidationException": {
                "description": "Validation error",
                "content": {
                    "application/json": {
                        "schema": {
                            "type": "object",
                            "properties": {
                                "message": {
                                    "type": "string",
                                    "description": "Errors overview."
                                },
                                "errors": {
                                    "type": "object",
                                    "description": "A detailed description of each field that failed validation.",
                                    "additionalProperties": {
                                        "type": "array",
                                        "items": {
                                            "type": "string"
                                        }
                                    }
                                }
                            },
                            "required": [
                                "message",
                                "errors"
                            ]
                        }
                    }
                }
            }
        }
    }
}